# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-random-string

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_BOT_USERNAME=your_bot_username

# Telegram Web App
TMA_URL=https://your-domain.tld
TMA_INIT_DATA_VALIDATION=true

# World ID / Worldcoin
WORLD_ID_APP_ID=app_xxx
WORLD_ID_CLIENT_SECRET=your-world-id-secret

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://exo_user:exo_password@postgres:5432/exo_genesis
DATABASE_URL_SYNC=postgresql://exo_user:exo_password@postgres:5432/exo_genesis

# Redis 7
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# TON Blockchain
TON_NETWORK=testnet
TON_API_KEY=your-ton-api-key
TON_MNEMONIC=word1 word2 word3 ... word24

# Smart Contract Addresses (filled after deployment)
XGEN_JETTON_ADDRESS=
FLEET_NFT_ADDRESS=
ARTIFACT_NFT_ADDRESS=
PILOT_SBT_ADDRESS=
BURN_VAULT_ADDRESS=

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Notifications
NOTIFICATION_ENABLED=true
NOTIFICATION_COOLDOWN_SECONDS=3600
